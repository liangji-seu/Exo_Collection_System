      "enum": [
        "NOT_SELECTED",
        "QUEUED",
        "TRANSFERRING",
        "TRANSFERRED",
        "VERIFYING",
        "VERIFIED",
        "FAILED"
      ],
      "title": "UploadState",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "1.1.0"
          }
        }
      },
      "then": {
        "properties": {
          "project_code": {
            "enum": [
              "F",
              "T"
            ]
          },
          "subject_code": {
            "pattern": "^[0-9]{3}$",
            "type": "string"
          }
        },
        "required": [
          "project_code",
          "subject_code"
        ]
      }
    }
  ],
  "description": "Schema for a single UUID-linked Trial package.",
  "properties": {
    "schema_version": {
      "default": "1.1.0",
      "enum": [
        "1.0.0",
        "1.1.0"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "manifest_uuid": {
      "format": "uuid",
      "title": "Manifest Uuid",
      "type": "string"
    },
    "project_uuid": {
      "format": "uuid",
      "title": "Project Uuid",
      "type": "string"
    },
    "project_code": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Project Code"
    },
    "project_name": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Project Name"
    },
    "subject_uuid": {
      "format": "uuid",
      "title": "Subject Uuid",
      "type": "string"
    },
    "subject_code": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Subject Code"
    },
    "session_uuid": {
      "format": "uuid",
      "title": "Session Uuid",
      "type": "string"
    },
    "trial_uuid": {
      "format": "uuid",
      "title": "Trial Uuid",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/TrialState"
    },
    "condition": {
      "$ref": "#/$defs/Condition"
    },
    "timing": {
      "$ref": "#/$defs/TrialTiming"
    },
    "software": {
      "$ref": "#/$defs/SoftwareProvenance"
    },
    "configuration": {
      "$ref": "#/$defs/ConfigurationSnapshot"
    },
    "devices": {
      "items": {
        "$ref": "#/$defs/DeviceProvenance"
      },
      "title": "Devices",
      "type": "array"
    },
    "modalities": {
      "items": {
        "$ref": "#/$defs/ModalityManifest"
      },
      "title": "Modalities",
      "type": "array"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/ManifestArtifact"
      },
      "title": "Artifacts",
      "type": "array"
    },
    "clock_and_alignment": {
      "$ref": "#/$defs/ClockAndAlignment"
    },
    "quality": {
      "$ref": "#/$defs/QualitySummary"
    },
    "abnormal_termination": {
      "$ref": "#/$defs/AbnormalTermination"
    },
    "external_artifacts": {
      "items": {
        "$ref": "#/$defs/ExternalArtifactReference"
      },
      "title": "External Artifacts",
      "type": "array"
    },
    "upload_records": {
      "items": {
        "$ref": "#/$defs/UploadRecordReference"
      },
      "title": "Upload Records",
      "type": "array"
    },
    "created_at_utc": {
      "format": "date-time",
      "title": "Created At Utc",
      "type": "string"
    }
  },
  "required": [
    "project_uuid",
    "subject_uuid",
    "session_uuid",
    "trial_uuid",
    "state",
    "condition",
    "timing",
    "software",
    "configuration"
  ],
  "title": "Exo Collection Trial Manifest 1.1.0",
  "type": "object",
  "$id": "https://exo-collection.local/schemas/manifest/1.1.0.json"
}
