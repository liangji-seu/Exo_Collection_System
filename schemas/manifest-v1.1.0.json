{
  "$defs": {
    "AbnormalTermination": {
      "additionalProperties": false,
      "properties": {
        "occurred": {
          "default": false,
          "title": "Occurred",
          "type": "boolean"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        },
        "error_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Code"
        },
        "last_state": {
          "anyOf": [
            {
              "$ref": "#/$defs/TrialState"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "occurred_at_utc": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Occurred At Utc"
        },
        "related_event_uuids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Related Event Uuids",
          "type": "array"
        },
        "recovery_notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recovery Notes"
        }
      },
      "title": "AbnormalTermination",
      "type": "object"
    },
    "AlignmentQuality": {
      "enum": [
        "GOOD",
        "ACCEPTABLE",
        "POOR",
        "UNAVAILABLE"
      ],
      "title": "AlignmentQuality",
      "type": "string"
    },
    "AlignmentRecord": {
      "additionalProperties": false,
      "properties": {
        "alignment_uuid": {
          "format": "uuid",
          "title": "Alignment Uuid",
          "type": "string"
        },
        "source_artifact_uuid": {
          "format": "uuid",
          "title": "Source Artifact Uuid",
          "type": "string"
        },
        "source_clock_domain": {
          "minLength": 1,
          "title": "Source Clock Domain",
          "type": "string"
        },
        "pulse_ids": {
          "items": {
            "type": "string"
          },
          "title": "Pulse Ids",
          "type": "array"
        },
        "mapping_uuid": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mapping Uuid"
        },
        "offset_only": {
          "default": false,
          "title": "Offset Only",
          "type": "boolean"
        },
        "quality": {
          "$ref": "#/$defs/AlignmentQuality",
          "default": "UNAVAILABLE"
        },
        "match_error_rms_ns": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Match Error Rms Ns"
        },
        "algorithm_version": {
          "minLength": 1,
          "title": "Algorithm Version",
          "type": "string"
        },
        "derived_artifact_uuid": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derived Artifact Uuid"
        },
        "created_at_utc": {
          "format": "date-time",
          "title": "Created At Utc",
          "type": "string"
        }
      },
      "required": [
        "source_artifact_uuid",
        "source_clock_domain",
        "algorithm_version"
      ],
      "title": "AlignmentRecord",
      "type": "object"
    },
    "ArtifactKind": {
      "enum": [
        "raw",
        "derived",
        "report",
        "external",
        "log"
      ],
      "title": "ArtifactKind",
      "type": "string"
    },
    "ClockAndAlignment": {
      "additionalProperties": false,
      "properties": {
        "common_clock_domain": {
          "const": "host_monotonic",
          "default": "host_monotonic",
          "title": "Common Clock Domain",
          "type": "string"
        },
        "host_clock_api": {
          "const": "time.perf_counter_ns",
          "default": "time.perf_counter_ns",
          "title": "Host Clock Api",
          "type": "string"
        },
        "clock_domains": {
          "items": {
            "$ref": "#/$defs/ClockDomainManifest"
          },
          "title": "Clock Domains",
          "type": "array"
        },
        "mappings": {
          "items": {
            "$ref": "#/$defs/ClockMapping"
          },
          "title": "Mappings",
          "type": "array"
        },
        "raw_sync_pulse_artifact_uuids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Raw Sync Pulse Artifact Uuids",
          "type": "array"
        },
        "sync_event_artifact_uuids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Sync Event Artifact Uuids",
          "type": "array"
        },
        "alignments": {
          "items": {
            "$ref": "#/$defs/AlignmentRecord"
          },
          "title": "Alignments",
          "type": "array"
        }
      },
      "title": "ClockAndAlignment",
      "type": "object"
    },
    "ClockDomainKind": {
      "enum": [
        "host_monotonic",
        "device_tick",
        "device_timestamp",
        "external"
      ],
      "title": "ClockDomainKind",
      "type": "string"
    },
    "ClockDomainManifest": {
      "additionalProperties": false,
      "properties": {
        "clock_domain": {
          "minLength": 1,
          "title": "Clock Domain",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ClockDomainKind"
        },
        "unit": {
          "minLength": 1,
          "title": "Unit",
          "type": "string"
        },
        "device_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Device Id"
        },
        "nominal_rate_hz": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Nominal Rate Hz"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "required": [
        "clock_domain",
        "kind",
        "unit"
      ],
      "title": "ClockDomainManifest",
      "type": "object"
    },
    "ClockMapping": {
      "additionalProperties": false,
      "description": "Persisted ``t_target_ns = a * t_source + b`` clock model.",
      "properties": {
        "mapping_uuid": {
          "format": "uuid",
          "title": "Mapping Uuid",
          "type": "string"
        },
        "source_clock_domain": {
          "minLength": 1,
          "title": "Source Clock Domain",
          "type": "string"
        },
        "target_clock_domain": {
          "default": "host_monotonic",
          "minLength": 1,
          "title": "Target Clock Domain",
          "type": "string"
        },
        "scale_a": {
          "title": "Scale A",
          "type": "number"
        },
        "offset_b_ns": {
          "title": "Offset B Ns",
          "type": "number"
        },
        "valid_source_start": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Valid Source Start"
        },
        "valid_source_end": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Valid Source End"
        },
        "anchor_count": {
          "minimum": 1,
          "title": "Anchor Count",
          "type": "integer"
        },
        "residuals": {
          "$ref": "#/$defs/ResidualStatistics"
        },
        "algorithm_version": {
          "minLength": 1,
          "title": "Algorithm Version",
          "type": "string"
        },
        "created_at_utc": {
          "format": "date-time",
          "title": "Created At Utc",
          "type": "string"
        }
      },
      "required": [
        "source_clock_domain",
        "scale_a",
        "offset_b_ns",
        "anchor_count",
        "residuals",
        "algorithm_version"
      ],
      "title": "ClockMapping",
      "type": "object"
    },
    "Condition": {
      "additionalProperties": false,
      "description": "Frozen snapshot of the condition selected before recording starts.\n\nCondition and signal quality are intentionally separate concepts.  A Trial\nembeds this snapshot; quality is recorded in ``Trial.quality_grade`` and the\nManifest quality summary.",
      "properties": {
        "condition_code": {
          "minLength": 1,
          "title": "Condition Code",
          "type": "string"
        },
        "condition_name": {
          "minLength": 1,
          "title": "Condition Name",
          "type": "string"
        },
        "condition_level": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Condition Level"
        },
        "levels": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ]
          },
          "title": "Levels",
          "type": "object"
        },
        "parameters": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Parameters",
          "type": "object"
        },
        "repeat_index": {
          "minimum": 1,
          "title": "Repeat Index",
          "type": "integer"
        },
        "protocol_version": {
          "minLength": 1,
          "title": "Protocol Version",
          "type": "string"
        },
        "grading_rule_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Grading Rule Version"
        },
        "selected_at_utc": {
          "format": "date-time",
          "title": "Selected At Utc",
          "type": "string"
        }
      },
      "required": [
        "condition_code",
        "condition_name",
        "repeat_index",
        "protocol_version"
      ],
      "title": "Condition",
      "type": "object"
    },
    "ConfigurationSnapshot": {
      "additionalProperties": false,
      "properties": {
        "config_version": {
          "minLength": 1,
          "title": "Config Version",
          "type": "string"
        },
        "protocol_version": {
          "minLength": 1,
          "title": "Protocol Version",
          "type": "string"
        },
        "condition_definition_version": {
          "minLength": 1,
          "title": "Condition Definition Version",
          "type": "string"
        },
        "content_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Sha256",
          "type": "string"
        },
        "snapshot_relative_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Snapshot Relative Path"
        },
        "source_files": {
          "items": {
            "type": "string"
          },
          "title": "Source Files",
          "type": "array"
        }
      },
      "required": [
        "config_version",
        "protocol_version",
        "condition_definition_version",
        "content_sha256"
      ],
      "title": "ConfigurationSnapshot",
      "type": "object"
    },
    "DeviceProvenance": {
