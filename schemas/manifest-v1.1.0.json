    "TrialState": {
      "description": "Persistent states for a single atomic Trial.",
      "enum": [
        "IDLE",
        "PREPARING",
        "READY",
        "WAITING_SYNC",
        "RECORDING",
        "STOPPING",
        "FINALIZING",
        "FINALIZED",
        "FAILED",
        "ABORTED",
        "RECOVERABLE"
      ],
      "title": "TrialState",
      "type": "string"
    },
    "TrialTiming": {
      "additionalProperties": false,
      "description": "Both audit time and the non-jumping common acquisition time.",
      "properties": {
        "started_at_utc": {
          "format": "date-time",
          "title": "Started At Utc",
          "type": "string"
        },
        "stopped_at_utc": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
