    "ExternalArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_uuid": {
          "format": "uuid",
          "title": "Artifact Uuid",
          "type": "string"
        },
        "source_system": {
          "minLength": 1,
          "title": "Source System",
          "type": "string"
        },
        "external_clock_domain": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "External Clock Domain"
        },
        "original_filename": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Original Filename"
        },
        "imported_at_utc": {
          "format": "date-time",
          "title": "Imported At Utc",
          "type": "string"
        },
        "alignment_uuid": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
