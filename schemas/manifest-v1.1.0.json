    "QualityGrade": {
      "enum": [
        "A",
        "B",
        "C",
        "INVALID"
      ],
      "title": "QualityGrade",
      "type": "string"
    },
    "QualityIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
