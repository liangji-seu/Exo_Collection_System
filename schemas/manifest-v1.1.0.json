        "remote_relative_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remote Relative Path"
        },
        "created_at_utc": {
          "format": "date-time",
          "title": "Created At Utc",
          "type": "string"
        },
