        "finalized_at_utc": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finalized At Utc"
        },
        "start_host_monotonic_ns": {
          "minimum": 0,
          "title": "Start Host Monotonic Ns",
          "type": "integer"
        },
        "stop_host_monotonic_ns": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stop Host Monotonic Ns"
        },
        "finalize_host_monotonic_ns": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finalize Host Monotonic Ns"
        }
      },
      "required": [
        "started_at_utc",
        "start_host_monotonic_ns"
      ],
      "title": "TrialTiming",
      "type": "object"
