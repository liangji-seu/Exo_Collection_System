      "enum": [
        "INFO",
        "WARNING",
        "ERROR"
      ],
      "title": "QualityIssueSeverity",
      "type": "string"
    },
    "QualitySummary": {
      "additionalProperties": false,
      "description": "Computed result plus a non-destructive optional human review.",
      "properties": {
