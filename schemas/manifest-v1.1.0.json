    "JsonValue": {},
    "ManifestArtifact": {
      "additionalProperties": false,
      "description": "An Artifact after Writer closure and integrity calculation.",
      "properties": {
        "artifact_uuid": {
          "format": "uuid",
          "title": "Artifact Uuid",
          "type": "string"
        },
        "trial_uuid": {
          "format": "uuid",
          "title": "Trial Uuid",
          "type": "string"
        },
        "modality": {
          "minLength": 1,
          "title": "Modality",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "relative_path": {
          "minLength": 1,
          "title": "Relative Path",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "created_at_utc": {
          "format": "date-time",
          "title": "Created At Utc",
          "type": "string"
        },
        "finalized_at_utc": {
          "format": "date-time",
          "title": "Finalized At Utc",
          "type": "string"
        },
        "source_artifact_uuids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Source Artifact Uuids",
          "type": "array"
        },
        "immutable": {
          "default": true,
          "title": "Immutable",
          "type": "boolean"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "trial_uuid",
        "modality",
        "kind",
        "media_type",
        "relative_path",
        "size_bytes",
        "sha256",
        "finalized_at_utc"
      ],
      "title": "ManifestArtifact",
      "type": "object"
    },
    "ModalityManifest": {
      "additionalProperties": false,
      "properties": {
        "modality": {
          "minLength": 1,
          "title": "Modality",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "adapter_type": {
          "minLength": 1,
          "title": "Adapter Type",
          "type": "string"
        },
        "writer_type": {
          "minLength": 1,
          "title": "Writer Type",
          "type": "string"
        },
        "clock_domain": {
          "minLength": 1,
          "title": "Clock Domain",
          "type": "string"
        },
        "device_ids": {
          "items": {
            "type": "string"
          },
          "title": "Device Ids",
          "type": "array"
        },
        "artifact_uuids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Artifact Uuids",
          "type": "array"
        },
        "channels": {
          "items": {
            "type": "string"
          },
          "title": "Channels",
          "type": "array"
        },
        "units": {
          "items": {
            "type": "string"
          },
          "title": "Units",
          "type": "array"
        },
        "sample_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sample Count"
        },
        "frame_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Frame Count"
        },
        "first_sample_index": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "First Sample Index"
        },
        "last_sample_index": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Sample Index"
        },
        "sequence_gap_count": {
          "default": 0,
          "minimum": 0,
          "title": "Sequence Gap Count",
          "type": "integer"
        },
        "nominal_sample_rate_hz": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Nominal Sample Rate Hz"
        },
        "actual_sample_rate_hz": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Actual Sample Rate Hz"
        },
        "metadata": {
          "additionalProperties": {
